# NZ Legislation Tool - Environment Variables
# Copy this file to .env and fill in your values

# Required: API Key from https://api.legislation.govt.nz
NZ_LEGISLATION_API_KEY=your_api_key_here

# Optional: API Base URL (default: https://api.legislation.govt.nz)
NZ_LEGISLATION_BASE_URL=https://api.legislation.govt.nz

# Optional: Request timeout in milliseconds (default: 30000)
NZ_LEGISLATION_TIMEOUT=30000

# Optional: Enable verbose logging (default: false)
NZ_LEGISLATION_VERBOSE=false
