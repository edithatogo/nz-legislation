{
  "name": "nz-legislation-tool",
  "version": "1.0.1",
  "description": "CLI tool for searching and retrieving New Zealand legislation data",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "nzlegislation": "./dist/cli.js",
    "nzlegislation-mcp": "./dist/mcp-cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp-cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "start:mcp": "node dist/mcp-cli.js",
    "test": "vitest",
    "bench": "tsx benchmarks/performance.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "nz",
    "legislation",
    "cli",
    "legal-tech",
    "research",
    "new-zealand",
    "api"
  ],
  "author": "Dylan Mordaunt <dylan.mordaunt@vuw.ac.nz>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/edithatogo/nz-legislation.git"
  },
  "bugs": {
    "url": "https://github.com/edithatogo/nz-legislation/issues"
  },
  "homepage": "https://github.com/edithatogo/nz-legislation#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "dotenv": "^16.4.5",
    "got": "^14.4.2",
    "ora": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/benchmark": "^2.1.5",
    "@types/node": "^20.14.11",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "benchmark": "^2.1.4",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
