{
  "name": "nz-legislation",
  "version": "1.0.1",
  "description": "CLI tool for searching and retrieving New Zealand legislation data",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "nzlegislation": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format cjs --dts --minify",
    "build:check": "tsc --noEmit",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "release": "changeset publish",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "keywords": [
    "nz",
    "new-zealand",
    "legislation",
    "law",
    "legal",
    "cli",
    "api",
    "research"
  ],
  "author": "Dylan Mordaunt <dylan.mordaunt@vuw.ac.nz>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/edithatogo/nz-legislation.git"
  },
  "bugs": {
    "url": "https://github.com/edithatogo/nz-legislation/issues"
  },
  "homepage": "https://github.com/edithatogo/nz-legislation#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.4.1",
    "commander": "^15.0.0",
    "inquirer": "^13.3.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.14.11",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.4",
    "@vitest/ui": "^2.0.4",
    "eslint": "^10.0.3",
    "msw": "^2.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "tsx": "^4.16.2",
    "typescript": "^6.0.0-rc",
    "vitest": "^2.0.4"
  },
  "msw": {
    "workerDirectory": "tests/mocks"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
