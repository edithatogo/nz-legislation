{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@models/*": ["src/models/*"],
      "@commands/*": ["src/commands/*"],
      "@utils/*": ["src/utils/*"],
      "@output/*": ["src/output/*"],
      "@mcp/*": ["src/mcp/*"],
      "@client": ["src/client"],
      "@config": ["src/config"],
      "@errors": ["src/errors"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
