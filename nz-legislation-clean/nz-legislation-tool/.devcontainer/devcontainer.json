{
  "name": "NZ Legislation Tool",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "vitest.explorer",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true
      }
    }
  },
  "forwardPorts": [8080],
  "postCreateCommand": "npm install && cp .env.example .env",
  "postStartCommand": "npm run dev -- --help",
  "remoteEnv": {
    "NZ_LEGISLATION_API_KEY": "${localEnv:NZ_LEGISLATION_API_KEY}"
  },
  "mounts": [
    "source=${localEnv:HOME}/.nz-legislation-tool,target=/home/node/.nz-legislation-tool,type=bind,consistency=cached"
  ]
}
