{
  "name": "nz-legislation-tool",
  "version": "1.2.0",
  "description": "CLI tool for searching and retrieving New Zealand legislation data",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "nzlegislation": "./dist/cli.js",
    "nzlegislation-mcp": "./dist/mcp-cli.js",
    "anzlegislation": "./dist/cli.js",
    "anzlegislation-mcp": "./dist/mcp-cli.js",
    "legislation": "./dist/cli.js",
    "legislation-mcp": "./dist/mcp-cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp-cli.ts",
    "build": "tsc && tsc-alias",
    "build:analyze": "tsx scripts/bundle-analyze.ts",
    "start": "node dist/cli.js",
    "start:mcp": "node dist/mcp-cli.js",
    "test": "node ./node_modules/vitest/vitest.mjs --config vitest.config.ts",
    "test:run": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "test:coverage": "node ./node_modules/vitest/vitest.mjs run --config vitest.config.ts --coverage",
    "gate:coverage": "tsx scripts/check-coverage-threshold.ts",
    "gate:no-placeholder-legal-data": "tsx scripts/check-no-placeholder-legal-data.ts",
    "bench": "tsx benchmarks/performance.ts",
    "bench:audit": "tsx benchmarks/performance-audit.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\" \"tests/**/*.{ts,js,json,md}\" \"scripts/**/*.{ts,js,json,md}\" \"docs/**/*.md\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\" \"tests/**/*.{ts,js,json,md}\" \"scripts/**/*.{ts,js,json,md}\" \"docs/**/*.md\" \"*.{json,md}\"",
    "lint:biome": "biome check src/ tests/",
    "lint:biome-fix": "biome check --write --unsafe src/ tests/",
    "format:biome": "biome format --write src/ tests/",
    "format:biome-check": "biome format src/ tests/",
    "lint:oxlint": "oxlint src/ tests/",
    "lint:oxlint-fix": "oxlint --fix src/ tests/",
    "lint:docs": "vale README.md docs/",
    "prepare": "husky",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "audit": "pnpm audit",
    "audit:fix": "pnpm audit --fix",
    "docs": "typedoc",
    "docs:serve": "npx http-server docs/api -p 8080 -o",
    "gate:conductor-requirements": "tsx scripts/check-conductor-requirements.ts",
    "gate:mirror-readiness": "tsx scripts/check-mirror-readiness.ts",
    "gate:manifest-docs": "tsx scripts/check-manifest-docs-drift.ts",
    "smoke:install-snippets": "tsx scripts/smoke-install-snippets.ts",
    "gate:install-snippets": "tsx scripts/check-install-snippets.ts && corepack pnpm smoke:install-snippets",
    "gate:security-provenance": "tsx scripts/check-security-provenance.ts",
    "gate:release-notes": "tsx scripts/check-release-notes.ts",
    "gate:package-metadata": "tsx scripts/check-package-metadata.ts",
    "gate:provider-capability-manifest": "node ./node_modules/vitest/vitest.mjs run tests/provider-capability-manifest.test.ts tests/provider-registry.test.ts tests/provider-source-cards.test.ts --config vitest.config.ts",
    "gate:provider-aware-mcp-export": "node ./node_modules/vitest/vitest.mjs run tests/provider-runtime.test.ts tests/mcp-provider-capability.test.ts tests/e2e/cli.test.ts --config vitest.config.ts",
    "gate:nz-stable-compatibility": "tsx scripts/check-nz-stable-compatibility.ts",
    "gate:brand-migration": "node ./node_modules/vitest/vitest.mjs run tests/legislation-brand-migration.test.ts --config vitest.config.ts",
    "gate:jurisdiction-mainstreaming": "node ./node_modules/vitest/vitest.mjs run tests/jurisdiction-mainstreaming.test.ts --config vitest.config.ts",
    "gate:commonwealth-fixtures": "node ./node_modules/vitest/vitest.mjs run tests/commonwealth-provider-fixtures.test.ts --config vitest.config.ts",
    "gate:act-provider-readiness": "node ./node_modules/vitest/vitest.mjs run tests/act-provider-readiness.test.ts --config vitest.config.ts",
    "gate:openapi-adapter-contract": "node ./node_modules/vitest/vitest.mjs run tests/openapi-adapter-contract.test.ts --config vitest.config.ts",
    "gate:website-docs": "tsx scripts/check-website-docs.ts",
    "gate:release-submission": "corepack pnpm gate:no-placeholder-legal-data && corepack pnpm gate:provider-capability-manifest && corepack pnpm gate:provider-aware-mcp-export && corepack pnpm gate:package-metadata && corepack pnpm gate:conductor-requirements && corepack pnpm gate:manifest-docs && corepack pnpm gate:website-docs && corepack pnpm gate:install-snippets && corepack pnpm gate:channel-readiness && corepack pnpm gate:assistant-integrations && corepack pnpm gate:ide-integrations && corepack pnpm gate:security-provenance && corepack pnpm gate:release-notes",
    "gate:channel-readiness": "tsx scripts/check-channel-readiness.ts",
    "gate:assistant-integrations": "tsx scripts/check-assistant-integrations.ts",
    "gate:ide-integrations": "tsx scripts/check-ide-integrations.ts",
    "docs:dev": "npm --prefix docs-site run dev",
    "docs:build": "npm --prefix docs-site run build",
    "docs:check": "npm --prefix docs-site run check"
  },
  "keywords": [
    "nz",
    "legislation",
    "cli",
    "legal-tech",
    "research",
    "new-zealand",
    "api"
  ],
  "author": "Dylan Mordaunt <dylan.mordaunt@vuw.ac.nz>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/edithatogo/nz-legislation.git"
  },
  "packageManager": "pnpm@10.29.3",
  "legalNz": {
    "versioning": "semver",
    "logging": "winston"
  },
  "bugs": {
    "url": "https://github.com/edithatogo/nz-legislation/issues"
  },
  "homepage": "https://github.com/edithatogo/nz-legislation#readme",
  "pnpm": {
    "overrides": {
      "vite": "7.3.5",
      "vitest>vite": "7.3.5"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "dotenv": "^16.4.5",
    "got": "^14.4.2",
    "lru-cache": "^11.2.6",
    "ora": "^8.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/cli": "^2.29.7",
    "@stryker-mutator/core": "^9.6.0",
    "@types/benchmark": "^2.1.5",
    "@types/node": "^20.14.11",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.1.0",
    "benchmark": "^2.1.4",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "execa": "^9.6.1",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "msw": "^2.12.10",
    "oxlint": "^1.71.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.16.2",
    "typedoc": "^0.28.20",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.56.1",
    "vite": "7.3.5",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "private": true
}
