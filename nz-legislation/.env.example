# NZ Legislation API Configuration
# Copy this file to .env and fill in your actual values

# API Authentication (required)
# Your API key from PCO: nzlapi3f4dd302e30beef18911
NZ_LEGISLATION_API_KEY=nzlapi3f4dd302e30beef18911

# API Base URL (optional - default is correct for most users)
NZ_LEGISLATION_BASE_URL=https://api.legislation.govt.nz

# API Documentation: https://api.legislation.govt.nz/docs/

# Rate Limits (from PCO):
# - 10,000 requests per key per day (resets at midnight local time)
# - 2,000 requests per IP per 5-minute period (burst limit)

# Request timeout in seconds (optional)
NZ_LEGISLATION_TIMEOUT=30

# Maximum retry attempts (optional)
NZ_LEGISLATION_MAX_RETRIES=3

# Rate limit - requests per minute (optional, for client-side limiting)
# PCO limit: 10000/day = ~7 per minute average, but burst allowed
NZ_LEGISLATION_RATE_LIMIT=100
